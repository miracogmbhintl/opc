---
import { baseUrl } from '../lib/base-url';

// Server-side diagnostic
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const checks = {
  urlSet: !!supabaseUrl,
  keySet: !!supabaseKey,
  urlValid: false,
  urlFormat: '',
  keyFormat: ''
};

if (supabaseUrl) {
  try {
    const url = new URL(supabaseUrl);
    checks.urlValid = true;
    checks.urlFormat = `${url.protocol}//${url.hostname}`;
  } catch (e) {
    checks.urlFormat = 'Invalid URL format';
  }
}

if (supabaseKey) {
  checks.keyFormat = `${supabaseKey.substring(0, 20)}... (${supabaseKey.length} chars)`;
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Supabase Diagnostic - Miraka & Co</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #F2F2F2;
      padding: 40px 20px;
      color: #1A1A1A;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
    }
    h1 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #000000;
    }
    .subtitle {
      font-size: 16px;
      color: #666666;
      margin-bottom: 32px;
    }
    .card {
      background: #FFFFFF;
      border-radius: 16px;
      padding: 32px;
      margin-bottom: 24px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      border: 1px solid #E5E5E5;
    }
    .card h2 {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 20px;
      color: #000000;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .status-icon {
      width: 24px;
      height: 24px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 14px;
    }
    .status-icon.success {
      background: #22C55E;
      color: #FFFFFF;
    }
    .status-icon.error {
      background: #DC2626;
      color: #FFFFFF;
    }
    .status-icon.warning {
      background: #FBBF24;
      color: #000000;
    }
    .check-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 16px;
      background: #FAFAFA;
      border-radius: 12px;
      margin-bottom: 12px;
      border: 1px solid #E5E5E5;
    }
    .check-item:last-child {
      margin-bottom: 0;
    }
    .check-icon {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .check-icon.success {
      background: #22C55E;
    }
    .check-icon.error {
      background: #DC2626;
    }
    .check-content {
      flex: 1;
    }
    .check-title {
      font-weight: 600;
      font-size: 15px;
      color: #000000;
      margin-bottom: 4px;
    }
    .check-desc {
      font-size: 14px;
      color: #666666;
      line-height: 1.6;
    }
    .code {
      background: #000000;
      color: #22C55E;
      padding: 16px;
      border-radius: 8px;
      font-family: 'Monaco', 'Courier New', monospace;
      font-size: 13px;
      overflow-x: auto;
      margin-top: 8px;
    }
    .code.error {
      color: #DC2626;
      background: #FEE2E2;
    }
    .button {
      display: inline-block;
      background: #000000;
      color: #FFFFFF;
      padding: 12px 24px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 14px;
      transition: background 0.2s ease;
      border: none;
      cursor: pointer;
      margin-right: 12px;
    }
    .button:hover {
      background: #333333;
    }
    .button.secondary {
      background: transparent;
      color: #000000;
      border: 1px solid #E5E5E5;
    }
    .button.secondary:hover {
      background: #FAFAFA;
    }
    .loading {
      display: none;
      width: 20px;
      height: 20px;
      border: 2px solid #E5E5E5;
      border-top-color: #000000;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin-left: 8px;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    #testResult {
      margin-top: 20px;
    }
    .alert {
      padding: 16px;
      border-radius: 8px;
      margin-bottom: 20px;
    }
    .alert.error {
      background: #FEE2E2;
      border: 1px solid #FCA5A5;
      color: #991B1B;
    }
    .alert.success {
      background: #D1FAE5;
      border: 1px solid #6EE7B7;
      color: #065F46;
    }
    .instructions {
      background: #FFFBEB;
      border: 1px solid #FDE68A;
      border-radius: 12px;
      padding: 20px;
      margin-top: 20px;
    }
    .instructions h3 {
      font-size: 16px;
      font-weight: 600;
      color: #92400E;
      margin-bottom: 12px;
    }
    .instructions ol {
      margin-left: 20px;
      color: #78350F;
      line-height: 1.8;
    }
    .instructions code {
      background: #FEF3C7;
      padding: 2px 6px;
      border-radius: 4px;
      font-family: 'Monaco', monospace;
      font-size: 13px;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>🔍 Supabase Configuration Diagnostic</h1>
    <p class="subtitle">This page will help you identify and fix authentication issues</p>

    <!-- Server-side Environment Check -->
    <div class="card">
      <h2>
        <div class="status-icon {checks.urlSet && checks.keySet && checks.urlValid ? 'success' : 'error'}">
          {checks.urlSet && checks.keySet && checks.urlValid ? '✓' : '✗'}
        </div>
        Environment Variables (Server-side)
      </h2>

      <div class="check-item">
        <div class="check-icon {checks.urlSet ? 'success' : 'error'}"></div>
        <div class="check-content">
          <div class="check-title">PUBLIC_SUPABASE_URL</div>
          <div class="check-desc">
            {checks.urlSet ? `Set: ${checks.urlFormat}` : 'Missing - Please add to your .env file'}
          </div>
        </div>
      </div>

      <div class="check-item">
        <div class="check-icon {checks.keySet ? 'success' : 'error'}"></div>
        <div class="check-content">
          <div class="check-title">PUBLIC_SUPABASE_ANON_KEY</div>
          <div class="check-desc">
            {checks.keySet ? `Set: ${checks.keyFormat}` : 'Missing - Please add to your .env file'}
          </div>
        </div>
      </div>

      <div class="check-item">
        <div class="check-icon {checks.urlValid ? 'success' : 'error'}"></div>
        <div class="check-content">
          <div class="check-title">URL Format Validation</div>
          <div class="check-desc">
            {checks.urlValid ? 'URL format is valid' : 'URL format is invalid or URL is missing'}
          </div>
        </div>
      </div>
    </div>

    <!-- Connection Test -->
    <div class="card">
      <h2>
        <div class="status-icon warning">?</div>
        Live Connection Test
      </h2>
      <p style="margin-bottom: 20px; color: #666666;">
        Test the actual connection to Supabase to verify your credentials work.
      </p>
      
      <button onclick="testConnection()" class="button">
        Test Connection
        <span class="loading" id="loading"></span>
      </button>
      
      <button onclick="window.location.href = '{baseUrl}/api/supabase-test'" class="button secondary">
        View Raw JSON
      </button>

      <div id="testResult"></div>
    </div>

    <!-- Instructions -->
    {(!checks.urlSet || !checks.keySet || !checks.urlValid) && (
      <div class="instructions">
        <h3>⚠️ How to Fix Configuration Issues</h3>
        <ol>
          <li>Open your <code>.env</code> file in the project root</li>
          <li>Add or update these lines:
            <div class="code" style="margin: 12px 0;">
              PUBLIC_SUPABASE_URL="https://your-project.supabase.co"<br/>
              PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
            </div>
          </li>
          <li>Get your credentials from <a href="https://app.supabase.com" target="_blank" style="color: #92400E; font-weight: 600;">app.supabase.com</a> → Your Project → Settings → API</li>
          <li><strong>Important:</strong> Restart your dev server after updating the .env file</li>
          <li>Refresh this page to verify the changes</li>
        </ol>
      </div>
    )}

    <!-- Back to Login -->
    <div style="margin-top: 32px; text-align: center;">
      <a href="{baseUrl}/miraka-co-portal" class="button">← Back to Login</a>
    </div>
  </div>

  <script define:vars={{ baseUrl }}>
    async function testConnection() {
      const loading = document.getElementById('loading');
      const resultDiv = document.getElementById('testResult');
      
      loading.style.display = 'inline-block';
      resultDiv.innerHTML = '';

      try {
        const response = await fetch(`${baseUrl}/api/supabase-test`);
        const data = await response.json();
        
        loading.style.display = 'none';

        if (data.status === 'OK') {
          resultDiv.innerHTML = `
            <div class="alert success">
              <strong>✓ Success!</strong> Supabase connection is working properly.
            </div>
            <div class="code">
${JSON.stringify(data, null, 2)}
            </div>
          `;
        } else {
          let errorMessage = 'Connection failed. ';
          
          if (data.checks?.connection?.error) {
            if (data.checks.connection.error.includes('Invalid API key') || 
                data.checks.connection.error.includes('apikey')) {
              errorMessage += 'Your API key appears to be invalid. Please verify PUBLIC_SUPABASE_ANON_KEY in your .env file.';
            } else if (data.checks.connection.error.includes('Failed to fetch') ||
                       data.checks.connection.error.includes('NetworkError')) {
              errorMessage += 'Cannot reach Supabase server. Check your PUBLIC_SUPABASE_URL or network connection.';
            } else {
              errorMessage += data.checks.connection.error;
            }
          }

          resultDiv.innerHTML = `
            <div class="alert error">
              <strong>✗ Error:</strong> ${errorMessage}
            </div>
            <div class="code error">
${JSON.stringify(data, null, 2)}
            </div>
          `;
        }
      } catch (error) {
        loading.style.display = 'none';
        resultDiv.innerHTML = `
          <div class="alert error">
            <strong>✗ Test Failed:</strong> ${error.message}
          </div>
        `;
      }
    }

    // Auto-run test if everything looks good
    if (${checks.urlSet && checks.keySet && checks.urlValid}) {
      setTimeout(testConnection, 500);
    }
  </script>
</body>
</html>
