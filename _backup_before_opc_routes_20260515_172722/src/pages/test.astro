<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Test Page</title>
  <style>
    body {
      font-family: sans-serif;
      padding: 40px;
      background: #f5f5f5;
    }
    .box {
      background: white;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
    }
    h1 {
      color: #333;
    }
    .success {
      color: green;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <div class="box">
    <h1>🎉 Test Page</h1>
    <p class="success">✓ Astro is working</p>
    <p>Time: {new Date().toISOString()}</p>
  </div>
  
  <div class="box">
    <h2>Environment</h2>
    <p>Mode: {import.meta.env.MODE}</p>
    <p>Base URL: {import.meta.env.BASE_URL}</p>
  </div>

  <div class="box">
    <h2>Links</h2>
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/health">Health Check</a></li>
      <li><a href="/miraka-co-portal">Portal</a></li>
    </ul>
  </div>
</body>
</html>
