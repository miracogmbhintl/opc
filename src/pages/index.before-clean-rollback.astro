---
import OPCLogin from '../components/OPCLogin';
---

<!doctype html>
<html lang="de">
  <head>
    
  <!-- Orange Pro Clean Web App / PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="shortcut icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

  <meta name="theme-color" content="#ff6a00" />
  <meta name="application-name" content="Orange Pro Clean" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Orange Pro Clean" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orange Pro Clean Portal Login</title>
    <meta
      name="description"
      content="Login für das Orange Pro Clean Kunden-, Einsatz- und Dispatch-Portal."
    />
    <link
      rel="icon"
      type="image/png"
      href="/favicon.ico"
    />
  </head>
  <body style="margin:0;">
    <OPCLogin client:load />
  </body>
</html>
