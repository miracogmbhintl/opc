---
import AdminClientCreator from '../components/AdminClientCreator';
import MirakaDashboardShell from '../components/MirakaDashboardShell';
import '../styles/miraka-portal.css';
---

<!DOCTYPE html>
<html lang="de">
<head>
  
  <!-- Orange Pro Clean Web App / PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="shortcut icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

  <meta name="theme-color" content="#ff6a00" />
  <meta name="application-name" content="Orange Pro Clean" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Orange Pro Clean" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kunde anlegen | Orange Pro Clean</title>
  <link
    rel="icon"
    type="image/png"
    href="/favicon.ico"
  />
</head>
<body>
  <MirakaDashboardShell
    client:only="react"
    title="Kunde anlegen"
    requiredRole={["owner", "admin"]}
    currentPath="/kunde-anlegen"
  >
    <AdminClientCreator client:only="react" />
  </MirakaDashboardShell>
</body>
</html>