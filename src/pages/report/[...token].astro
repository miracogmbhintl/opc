---
import PublicTicketForm from "../../components/PublicTicketForm";

export const prerender = false;

const rawToken = Astro.params.token || "";
const token = Array.isArray(rawToken) ? rawToken.join("/") : rawToken;
---

<html lang="de">
  <head>
    
  <!-- Orange Pro Clean Web App / PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="shortcut icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

  <meta name="theme-color" content="#ff6a00" />
  <meta name="application-name" content="Orange Pro Clean" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Orange Pro Clean" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Orange Pro Clean Meldung</title>
    <meta
      name="description"
      content="Melden Sie Schäden, Reinigungsbedarf oder Hinweise direkt an Orange Pro Clean."
    />
  </head>

  <body style="margin:0;">
    <PublicTicketForm token={token} client:load />
  </body>
</html>
