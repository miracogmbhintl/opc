---
import Layout from '../../layouts/main.astro';
import MirakaDashboardShell from '../../components/MirakaDashboardShell';
import ClientDetail from '../../components/ClientDetail';
import { baseUrl } from '../../lib/base-url';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect(`${baseUrl}/kunden`);
}
---

<Layout>
  <MirakaDashboardShell
    client:only="react"
    requiredRole={["owner", "admin"]}
    currentPath={`/kunde/${id}`}
    hideTopBar={true}
  >
    <ClientDetail client:only="react" clientId={id} baseUrl={baseUrl} />
  </MirakaDashboardShell>
</Layout>