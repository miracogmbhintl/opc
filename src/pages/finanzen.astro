---
import FinancePage from '../components/FinancePage';
---

<!DOCTYPE html>
<html transition:name="root" transition:animate="none" lang="de">
  <head>
    <script is:inline>
      (() => {
        if (window.__OPC_NO_MOTION_VIEW_TRANSITIONS__) return;
        window.__OPC_NO_MOTION_VIEW_TRANSITIONS__ = true;

        const noMotionTransition = (callback) => {
          let callbackResult;

          try {
            callbackResult = typeof callback === 'function' ? callback() : undefined;
          } catch (error) {
            const rejected = Promise.reject(error);

            return {
              ready: rejected,
              updateCallbackDone: rejected,
              finished: rejected,
              skipTransition() {},
            };
          }

          const done = Promise.resolve(callbackResult);

          return {
            ready: done,
            updateCallbackDone: done,
            finished: done,
            skipTransition() {},
          };
        };

        try {
          Object.defineProperty(document, 'startViewTransition', {
            configurable: true,
            writable: true,
            value: noMotionTransition,
          });
        } catch {
          document.startViewTransition = noMotionTransition;
        }
      })();
    </script>

    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
    <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

    <meta name="theme-color" content="#ff6a00" />
    <meta name="application-name" content="Orange Pro Clean" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Finanzen | Orange Pro Clean</title>

    <style is:global>
      html,
      body {
        width: 100%;
        min-width: 0;
        min-height: 100%;
        margin: 0;
        padding: 0;
        background: #ffffff;
      }

      body {
        overflow-x: hidden;
      }

      .finanzen-page-root {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
        display: block;
      }

      .finanzen-page-root > astro-island,
      body > astro-island {
        width: 100%;
        max-width: none;
        margin: 0;
        padding: 0;
        display: block;
      }
    </style>
  </head>

  <body>
    <main class="finanzen-page-root">
      <FinancePage client:only="react" />
    </main>
  </body>
</html>
