---
import MirakaDashboardShell from '../components/MirakaDashboardShell';
import SettingsPageTranslated from '../components/SettingsPageTranslated';
import '../styles/miraka-portal.css';
import '../styles/miraka-dashboard.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Einstellungen | Orange Pro Clean</title>
  <link rel="icon" type="image/png" href="/favicon.ico" />
</head>
<body>
  <MirakaDashboardShell 
    client:only="react"
    requiredRole={['owner', 'admin', 'client']}
    currentPath="/einstellungen"
    fullWidth={true}
  >
    <SettingsPageTranslated client:only="react" />
  </MirakaDashboardShell>
</body>
</html>



