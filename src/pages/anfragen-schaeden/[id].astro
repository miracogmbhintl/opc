---
import MirakaDashboardShell from '../../components/MirakaDashboardShell';
import TicketDetailPage from '../../components/TicketDetailPage';

export const prerender = false;

const ticketId = Astro.params.id || '';
---

<!DOCTYPE html>
<html lang="de">
<head>
  
  <!-- Orange Pro Clean Web App / PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="shortcut icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

  <meta name="theme-color" content="#ff6a00" />
  <meta name="application-name" content="Orange Pro Clean" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Orange Pro Clean" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ticket Details - Orange Pro Clean</title>
</head>

<body>
  <MirakaDashboardShell
    client:only="react"
    requiredRole={['owner', 'admin', 'dispatch', 'employee', 'client']}
    currentPath="/anfragen-schaeden"
    fullWidth={true}
    hideTopBar={true}
  >
    <TicketDetailPage ticketId={ticketId} client:only="react" />
  </MirakaDashboardShell>
</body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    font-family: Inter, Helvetica, Arial, sans-serif;
  }

  :global(*) {
    box-sizing: border-box;
  }
</style>
