  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />
  <meta name="theme-color" content="#ff6a00" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Offerte | Orange Pro Clean</title>
</head>
<body>
  <QuoteDetailPage client:only="react" quoteId={id || ''} />
</body>
</html>
