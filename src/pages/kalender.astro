---
import MirakaDashboardShell from '../components/MirakaDashboardShell';
import OPCCalendarPage from '../components/opc/calendar/OPCCalendarPage';

export const prerender = false;
---

<!DOCTYPE html>
<html transition:name="root" transition:animate="none" lang="de">
<head>
    <script is:inline>
    (() => {
      if (window.__OPC_NO_MOTION_VIEW_TRANSITIONS__) return;

      window.__OPC_NO_MOTION_VIEW_TRANSITIONS__ = true;

      const noMotionTransition = (callback) => {
        let callbackResult;

        try {
          callbackResult = typeof callback === 'function' ? callback() : undefined;
        } catch (error) {
          const rejected = Promise.reject(error);

          return {
            ready: rejected,
            updateCallbackDone: rejected,
            finished: rejected,
            skipTransition() {},
          };
        }

        const done = Promise.resolve(callbackResult);

        return {
          ready: done,
          updateCallbackDone: done,
          finished: done,
          skipTransition() {},
        };
      };

      try {
        Object.defineProperty(document, 'startViewTransition', {
          configurable: true,
          writable: true,
          value: noMotionTransition,
        });
      } catch {
        document.startViewTransition = noMotionTransition;
      }
    })();
  </script>
  
  <!-- Orange Pro Clean Web App / PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="shortcut icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

  <meta name="theme-color" content="#ff6a00" />
  <meta name="application-name" content="Orange Pro Clean" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Orange Pro Clean" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Kalender | Orange Pro Clean</title>
  <link
    rel="icon"
    type="image/png"
    href="/favicon.ico"
  />
</head>

<body>
  <MirakaDashboardShell
    client:only="react"
    requiredRole={['owner', 'admin', 'dispatch', 'employee']}
    currentPath="/kalender"
    fullWidth={true}
    hideTopBar={true}
  >
    <OPCCalendarPage client:only="react" />
  </MirakaDashboardShell>

  <script is:inline>
    (() => {
      if (window.__OPC_TEAM_CALENDAR_DEFAULTS__) return;
      window.__OPC_TEAM_CALENDAR_DEFAULTS__ = true;

      const dispatchChange = (select, value) => {
        if (!select || select.value === value) return;
        select.value = value;
        select.dispatchEvent(new Event('change', { bubbles: true }));
      };

      const findTeamOption = (select) =>
        Array.from(select?.options || []).find((option) => {
          const label = String(option.textContent || '').toLowerCase();
          return label.includes('team') || label.includes('gesamtes team');
        });

      const applyDefaults = () => {
        const page = document.querySelector('.opc-calendar-page');

        if (page && page.dataset.teamCalendarDefaultApplied !== 'true') {
          const filterSelect = Array.from(page.querySelectorAll('select')).find((select) => {
            const values = Array.from(select.options).map((option) => option.value);
            return values.includes('team') && values.includes('all') && values.includes('employee');
          });

          if (filterSelect) {
            dispatchChange(filterSelect, 'team');
            page.dataset.teamCalendarDefaultApplied = 'true';
          }
        }

        document.querySelectorAll('[role="dialog"]').forEach((dialog) => {
          const heading = String(dialog.querySelector('h2')?.textContent || '').toLowerCase();
          const isNewEntry = heading.includes('neuer kalendereintrag') || heading.includes('google meet');
          if (!isNewEntry) return;

          const calendarLabel = Array.from(dialog.querySelectorAll('label')).find((label) =>
            String(label.childNodes[0]?.textContent || label.textContent || '')
              .trim()
              .toLowerCase()
              .startsWith('kalender'),
          );
          const select = calendarLabel?.querySelector('select');
          if (!select || select.dataset.teamCalendarDefaultApplied === 'true') return;

          const teamOption = findTeamOption(select);
          if (!teamOption) return;

          dispatchChange(select, teamOption.value);
          select.dataset.teamCalendarDefaultApplied = 'true';
        });
      };

      const observer = new MutationObserver(applyDefaults);
      observer.observe(document.documentElement, { childList: true, subtree: true });
      document.addEventListener('astro:page-load', applyDefaults);
      applyDefaults();
    })();
  </script>
</body>
</html>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    background: #ffffff;
    font-family: Inter, Helvetica, Arial, sans-serif;
  }

  :global(*) {
    box-sizing: border-box;
  }
</style>
