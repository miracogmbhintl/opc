---
import MirakaDashboardShell from '../components/MirakaDashboardShell';
import OwnerDashboardHome from '../components/OwnerDashboardHome';
import '../styles/miraka-portal.css';
import '../styles/miraka-dashboard.css';
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | Orange Pro Clean</title>
  <link
    rel="icon"
    type="image/png"
    href="/favicon.ico"
  />
</head>
<body>
  <MirakaDashboardShell
    client:only="react"
    title="Orange Pro Clean Dashboard"
    requiredRole="owner"
    currentPath="/dashboard"
    hideTopBar={true}
  >
    <OwnerDashboardHome client:only="react" />
  </MirakaDashboardShell>
</body>
</html>