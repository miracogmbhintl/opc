---
import InvoicesPage from '../components/InvoicesPage';
---

<!DOCTYPE html>
<html transition:name="root" transition:animate="none" lang="de">
  <head>
    <script is:inline>
      (() => {
        if (window.__OPC_NO_MOTION_VIEW_TRANSITIONS__) return;
        window.__OPC_NO_MOTION_VIEW_TRANSITIONS__ = true;
        const noMotionTransition = (callback) => {
          let callbackResult;
          try { callbackResult = typeof callback === 'function' ? callback() : undefined; }
          catch (error) {
            const rejected = Promise.reject(error);
            return { ready: rejected, updateCallbackDone: rejected, finished: rejected, skipTransition() {} };
          }
          const done = Promise.resolve(callbackResult);
          return { ready: done, updateCallbackDone: done, finished: done, skipTransition() {} };
        };
        try { Object.defineProperty(document, 'startViewTransition', { configurable: true, writable: true, value: noMotionTransition }); }
        catch { document.startViewTransition = noMotionTransition; }
      })();
    </script>
    <script is:inline src="/opc-owner-finance-guard.js"></script>
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
    <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />
    <meta name="theme-color" content="#ff6a00" />
    <meta name="application-name" content="Orange Pro Clean" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Rechnungen | Orange Pro Clean</title>
  </head>
  <body><InvoicesPage client:only="react" /></body>
</html>
