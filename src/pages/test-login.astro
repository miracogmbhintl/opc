---
import { baseUrl } from '../lib/base-url';
---

<!DOCTYPE html>
<html lang="en">
<head>
  
  <!-- Orange Pro Clean Web App / PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="shortcut icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

  <meta name="theme-color" content="#ff6a00" />
  <meta name="application-name" content="Orange Pro Clean" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Orange Pro Clean" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>Test Login - Miraka & Co</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #F2F2F2;
      padding: 40px 20px;
      color: #1A1A1A;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .container {
      max-width: 500px;
      width: 100%;
    }
    .card {
      background: #FFFFFF;
      border-radius: 20px;
      padding: 40px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }
    h1 {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #000000;
      text-align: center;
    }
    .subtitle {
      text-align: center;
      color: #666666;
      margin-bottom: 32px;
      font-size: 14px;
    }
    .form-group {
      margin-bottom: 20px;
    }
    label {
      display: block;
      font-weight: 600;
      font-size: 14px;
      color: #000000;
      margin-bottom: 6px;
    }
    input {
      width: 100%;
      height: 48px;
      padding: 0 16px;
      font-size: 15px;
      border-radius: 12px;
      border: 1.5px solid #E5E5E5;
      background: #FFFFFF;
      color: #000000;
      outline: none;
      transition: border-color 0.2s ease;
    }
    input:focus {
      border-color: #000000;
    }
    button {
      width: 100%;
      height: 48px;
      background: #000000;
      color: #FFFFFF;
      font-size: 15px;
      font-weight: 600;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      transition: background 0.2s ease;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    button:hover:not(:disabled) {
      background: #333333;
    }
    button:disabled {
      background: #999999;
      cursor: not-allowed;
    }
    .result {
      margin-top: 24px;
      padding: 16px;
      border-radius: 12px;
      font-size: 14px;
      line-height: 1.6;
      display: none;
    }
    .result.show {
      display: block;
    }
    .result.success {
      background: #D1FAE5;
      border: 1px solid #6EE7B7;
      color: #065F46;
    }
    .result.error {
      background: #FEE2E2;
      border: 1px solid #FCA5A5;
      color: #991B1B;
    }
    .result pre {
      margin-top: 12px;
      background: rgba(0,0,0,0.05);
      padding: 12px;
      border-radius: 6px;
      font-size: 12px;
      overflow-x: auto;
    }
    .loading {
      display: none;
      width: 20px;
      height: 20px;
      border: 2px solid #FFFFFF;
      border-top-color: transparent;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto;
    }
    .loading.show {
      display: block;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .links {
      margin-top: 24px;
      padding-top: 24px;
      border-top: 1px solid #E5E5E5;
      text-align: center;
    }
    .links a {
      color: #666666;
      text-decoration: none;
      font-size: 14px;
      margin: 0 12px;
      transition: color 0.2s ease;
    }
    .links a:hover {
      color: #000000;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="card">
      <h1>🔐 Login Test</h1>
      <p class="subtitle">Test your login credentials and connection</p>

      <form id="testForm">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="you@company.com"
            required
          />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="Enter your password"
            required
          />
        </div>

        <button type="submit" id="submitBtn">
          <span id="btnText">Test Login</span>
          <div class="loading" id="loading"></div>
        </button>
      </form>

      <div id="result" class="result"></div>

      <div class="links">
        <a href={`${baseUrl}/verify-supabase`}>Check Connection</a>
        <a href={`${baseUrl}/`}>Go to Login</a>
        <a href={`${baseUrl}/supabase-diagnostic`}>Full Diagnostic</a>
      </div>
    </div>
  </div>

  <script define:vars={{ baseUrl }}>
    const form = document.getElementById('testForm');
    const resultDiv = document.getElementById('result');
    const submitBtn = document.getElementById('submitBtn');
    const btnText = document.getElementById('btnText');
    const loading = document.getElementById('loading');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;

      // Show loading
      submitBtn.disabled = true;
      btnText.style.display = 'none';
      loading.classList.add('show');
      resultDiv.classList.remove('show');

      try {
        const response = await fetch(`${baseUrl}/api/test-login`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ email, password })
        });

        const data = await response.json();

        // Hide loading
        submitBtn.disabled = false;
        btnText.style.display = 'block';
        loading.classList.remove('show');

        // Show result
        resultDiv.classList.add('show');

        if (data.success) {
          resultDiv.className = 'result success show';
          resultDiv.innerHTML = `
            <strong>✓ Login Successful!</strong><br/>
            Your credentials are working correctly.
            <pre>${JSON.stringify(data, null, 2)}</pre>
            <div style="margin-top: 16px;">
              <a href="${baseUrl}/" style="color: #059669; font-weight: 600; text-decoration: underline;">
                Go to Login Page →
              </a>
            </div>
          `;
        } else {
          resultDiv.className = 'result error show';
          resultDiv.innerHTML = `
            <strong>✗ Login Failed</strong><br/>
            ${data.error}
            ${data.details ? '<pre>' + JSON.stringify(data, null, 2) + '</pre>' : ''}
            <div style="margin-top: 12px; font-size: 13px;">
              <strong>Possible issues:</strong><br/>
              • Wrong email or password<br/>
              • User account doesn't exist<br/>
              • Email not confirmed<br/>
              • Supabase connection issue<br/>
              • User profile not created
            </div>
          `;
        }
      } catch (error) {
        submitBtn.disabled = false;
        btnText.style.display = 'block';
        loading.classList.remove('show');

        resultDiv.className = 'result error show';
        resultDiv.innerHTML = `
          <strong>✗ Request Failed</strong><br/>
          ${error.message}
          <div style="margin-top: 12px; font-size: 13px;">
            This could be a network issue or server problem.
          </div>
        `;
      }
    });
  </script>
</body>
</html>
