---
import EmployeeTimeTrackingDetailPage from '../../components/EmployeeTimeTrackingDetailPage';
import '../../styles/miraka-portal.css';
import '../../styles/miraka-dashboard.css';

const { staffRoleId } = Astro.params;
---

<!DOCTYPE html>
<html lang="de">
<head>
  
  <!-- Orange Pro Clean Web App / PWA -->
  <link rel="manifest" href="/manifest.webmanifest" />
  <link rel="icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="shortcut icon" type="image/png" href="/icons/orange-pro-clean-webicon.png" />
  <link rel="apple-touch-icon" href="/icons/orange-pro-clean-webicon.png" />

  <meta name="theme-color" content="#ff6a00" />
  <meta name="application-name" content="Orange Pro Clean" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Orange Pro Clean" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zeiterfassung Details - Orange Pro Clean</title>
  <link
    rel="icon"
    type="image/png"
    href="https://cdn.prod.website-files.com/6944470386300e196e5fc347/694ff7f9812baa5c05309365_Orange%20Pro%20Clean%20GmbH%20WEBICON.png"
  />
</head>
<body>
  <EmployeeTimeTrackingDetailPage client:only="react" staffRoleId={staffRoleId} />
</body>
</html>