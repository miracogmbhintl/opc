





---
import '../../generated/fonts.css';
import '../site-components/global.css';
import '../styles/global.css';
import '../styles/miraka-unified.css';
import '../styles/work-os.css';
import { baseUrl } from '../lib/base-url';

const { pageClass = '', title: explicitTitle } = Astro.props;

const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const PAGE_TITLES: Record<string, string> = {
  '/': 'Login | Orange Pro Clean',
  '/dashboard': 'Dashboard | Orange Pro Clean',
  '/kunden': 'Kunden | Orange Pro Clean',
  '/kunde-anlegen': 'Kunde anlegen | Orange Pro Clean',
  '/anfragen': 'Anfragen | Orange Pro Clean',
  '/anfragen-schaeden': 'Tickets & Schäden | Orange Pro Clean',
  '/kalender': 'Kalender | Orange Pro Clean',
  '/einsaetze': 'Einsätze | Orange Pro Clean',
  '/einsatz-planen': 'Einsatz planen | Orange Pro Clean',
  '/berichte-dateien': 'Berichte & Dateien | Orange Pro Clean',
  '/qr-codes': 'QR-Codes | Orange Pro Clean',
  '/einstellungen': 'Einstellungen | Orange Pro Clean',
  '/forgot-password': 'Passwort vergessen | Orange Pro Clean',
  '/reset-password': 'Passwort zurücksetzen | Orange Pro Clean',
  '/set-password': 'Passwort setzen | Orange Pro Clean',
  '/logout': 'Abmelden | Orange Pro Clean',
  '/auth-redirect': 'Weiterleitung | Orange Pro Clean',
  '/emergency-login': 'Notfall Login | Orange Pro Clean',
};

const pageTitle =
  explicitTitle ||
  PAGE_TITLES[normalizedPath] ||
  (normalizedPath.startsWith('/kunde/') ? 'Kundendetail | Orange Pro Clean' : null) ||
  (normalizedPath.startsWith('/einsatz/') ? 'Einsatzdetail | Orange Pro Clean' : null) ||
  (normalizedPath.startsWith('/report/') ? 'Bericht | Orange Pro Clean' : null) ||
  'Orange Pro Clean Portal';
---

<html lang="de" class={pageClass}>
<head>
<meta charset="utf-8" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/favicon.ico" />
<link rel="manifest" href="/manifest.json" />
<meta name="theme-color" content="#F7931F" />
<meta name="viewport" content="width=device-width" />
<meta name="generator" content={Astro.generator} />
<title>{pageTitle}</title>
<meta name="description" content="Orange Pro Clean Kunden- und Mitarbeiterportal für Einsätze, Tickets, QR-Codes, Kalender, Berichte und Einstellungen." />
<meta property="og:title" content="Orange Pro Clean Portal" />
<meta property="og:description" content="Kunden- und Mitarbeiterportal der Orange Pro Clean GmbH." />
<meta property="og:type" content="website" />
<meta property="og:image" content="/favicon.svg" />
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content="Orange Pro Clean Portal" />
<meta name="twitter:description" content="Kunden- und Mitarbeiterportal der Orange Pro Clean GmbH." />
<!-- Prevent flash of unstyled content for dark mode -->
<script is:inline>
(function() {
const theme = localStorage.getItem('mco_theme');
if (theme === 'dark') {
document.documentElement.classList.add('dark');
}
})();
</script>

</head>
<body style="position: relative; overflow-x: hidden;">
<slot />
</body>
</html>








<style is:global>
/* Page-specific overrides */
html.splash main { 
display: flex !important; 
}

html.splash ol,
html.splash ul { 
padding-left: 0 !important; 
margin: 0 !important; 
}

/* Prevent any overflow issues */
body, html {
position: relative;
}

/* Disable all slide/transition animations on page load */
body,
html,
main,
*::before,
*::after {
  animation: none !important;
}

/* Explicitly disable view-transition animations */
::view-transition,
::view-transition-old(root),
::view-transition-new(root),
::view-transition-group(root),
::view-transition-image-pair(root),
::view-transition-backdrop {
  animation: none !important;
  opacity: 1 !important;
  transform: none !important;
}

/* Hide scrollbars completely on mobile */
@media (max-width: 768px) {
html, body {
overflow-x: hidden !important;
scrollbar-width: none !important;
-ms-overflow-style: none !important;
}

html::-webkit-scrollbar,
body::-webkit-scrollbar,
*::-webkit-scrollbar {
display: none !important;
width: 0 !important;
height: 0 !important;
}

* {
scrollbar-width: none !important;
-ms-overflow-style: none !important;
}
}
</style>
